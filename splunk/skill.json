{
  "name": "splunk",
  "version": "2.0.0",
  "description": "Ship deploy and fleet events to Splunk via HEC",
  "author": "muster",
  "hooks": [
    "post-deploy",
    "post-rollback",
    "fleet-deploy-end",
    "fleet-machine-deploy-end",
    "fleet-rollback-end"
  ],
  "requires": ["curl"],
  "config": [
    {
      "key": "MUSTER_SPLUNK_HEC_URL",
      "label": "Splunk HEC URL",
      "hint": "e.g. https://your-splunk:8088/services/collector/event"
    },
    {
      "key": "MUSTER_SPLUNK_HEC_TOKEN",
      "label": "Splunk HEC Token",
      "hint": "Settings > Data Inputs > HTTP Event Collector > New Token",
      "secret": true
    }
  ]
}
